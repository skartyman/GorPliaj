{
  "name": "gorpliaj-pwa",
  "version": "1.0.0",
  "description": "PWA сайт пляжно-ресторанного комплекса с меню и бронями",
  "main": "src/server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "localization:repair": "node scripts/repair-localization.js",
    "admin:dev": "npm --prefix admin-frontend run dev",
    "admin:build": "npm --prefix admin-frontend run build",
    "public:dev": "npm --prefix public-frontend run dev",
    "public:build": "npm --prefix public-frontend run build"
  },
  "keywords": [
    "pwa",
    "restaurant",
    "booking",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.892.0",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "prisma": "^6.19.2"
  }
}
