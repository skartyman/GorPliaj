generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Map {
  id              Int           @id @default(autoincrement())
  name            Json
  slug            String        @unique
  description     Json?
  status          MapStatus     @default(DRAFT)
  usageMode       MapUsageMode  @default(DAY)
  isDefault       Boolean       @default(false)
  width           Int
  height          Int
  backgroundImage String?
  backgroundColor String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
  tables          VenueTable[]
  zones           Zone[]
  mapObjects      MapObject[]

  @@index([status])
  @@index([isDefault])
  @@index([usageMode])
}

model Zone {
  id           Int           @id @default(autoincrement())
  mapId        Int
  name         Json
  color        String
  sortOrder    Int           @default(0)
  viewportJson Json?
  polygonJson  Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  map          Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  tables       VenueTable[]
  rows         BeachRow[]

  @@index([mapId])
}

model VenueTable {
  id           Int           @id @default(autoincrement())
  mapId        Int
  zoneId       Int
  name         Json
  code         String?
  bookingKind  BookingKind   @default(TABLE)
  positionType String?
  positionSide VenuePositionSide?
  rowId        Int?
  photoUrl     String?
  serviceName  Json?
  serviceDescription Json?
  seatsMin     Int
  seatsMax     Int
  deposit      Decimal       @db.Decimal(10, 2)
  price        Decimal?      @db.Decimal(10, 2)
  priceWeekday  Decimal?      @db.Decimal(10, 2)
  priceWeekend  Decimal?      @db.Decimal(10, 2)
  depositWeekday Decimal?      @db.Decimal(10, 2)
  depositWeekend Decimal?      @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  isBookable   Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  map          Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  zone         Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  row          BeachRow?     @relation(fields: [rowId], references: [id], onDelete: SetNull)
  mapObjects   MapObject[]
  reservations Reservation[]
  tableHolds   TableHold[]
  overrides    VenueTableOverride[]
  orders       TableOrder[]
  calls        WaiterCall[]
  favorites    GuestFavoriteUnit[]

  @@index([mapId])
  @@index([zoneId])
  @@index([bookingKind])
  @@index([sortOrder])
}

model VenueTableOverride {
  id         Int       @id @default(autoincrement())
  tableId     Int
  eventId     Int?
  ruleDate    DateTime?
  deposit     Decimal?  @db.Decimal(10, 2)
  price       Decimal?  @db.Decimal(10, 2)
  isActive    Boolean?
  isBookable  Boolean?
  photoUrl    String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  table       VenueTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  event       Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([tableId])
  @@index([eventId])
  @@index([ruleDate])
}

model PositionType {
  id              Int             @id @default(autoincrement())
  value           String          @unique
  name            Json
  description     Json?
  photoUrl        String?
  defaultPrice    Decimal?        @db.Decimal(10, 2)
  defaultDeposit  Decimal?        @db.Decimal(10, 2)
  priceWeekday    Decimal?        @db.Decimal(10, 2)
  priceWeekend    Decimal?        @db.Decimal(10, 2)
  depositWeekday  Decimal?        @db.Decimal(10, 2)
  depositWeekend  Decimal?        @db.Decimal(10, 2)
  code            String
  requiresSide    Boolean         @default(false)
  bookingKind     String
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model BeachRow {
  id        Int      @id @default(autoincrement())
  zoneId    Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zone      Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  tables    VenueTable[]
}

model MapObject {
  id        Int           @id @default(autoincrement())
  mapId     Int
  tableId   Int?
  type      MapObjectType
  label     Json?
  x         Float
  y         Float
  width     Float
  height    Float
  rotation  Float         @default(0)
  zIndex    Int           @default(0)
  styleJson Json?
  metaJson  Json?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  map       Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  table     VenueTable?   @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([mapId])
  @@index([tableId])
  @@index([isActive])
}

model Reservation {
  id              Int               @id @default(autoincrement())
  bookingGroupId  String?
  isGroupLead     Boolean           @default(false)
  groupGuestCount Int?
  tableId         Int
  mapId           Int
  zoneId          Int
  eventId         Int?
  bookingKind     BookingKind       @default(TABLE)
  customerName    String
  customerPhone   String
  customerEmail   String?
  guests          Int
  reservationDate DateTime
  timeFrom        DateTime
  timeTo          DateTime
  status          ReservationStatus @default(PENDING)
  source          ReservationSource @default(WEB)
  ticketCode      String?           @unique
  arrivedAt       DateTime?
  arrivedGuests   Int?
  commentCustomer String?
  commentAdmin    String?
  depositRequired Boolean           @default(false)
  depositAmount   Decimal?          @db.Decimal(10, 2)
  rentalAmount    Decimal?          @db.Decimal(10, 2)
  paidInCash      Boolean           @default(false)
  onPremises      Boolean           @default(false)
  onPremisesNote  String?
  analyticsDistinctId String?
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  event           Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  map             Map               @relation(fields: [mapId], references: [id], onDelete: Restrict)
  zone            Zone              @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  table           VenueTable        @relation(fields: [tableId], references: [id], onDelete: Restrict)
  payment         Payment?
  logs            ReservationLog[]
  tableHolds      TableHold[]
  guest           Guest?          @relation(fields: [guestId], references: [id], onDelete: SetNull)
  guestId         Int?

  @@index([tableId])
  @@index([bookingGroupId])
  @@index([mapId])
  @@index([zoneId])
  @@index([eventId])
  @@index([reservationDate])
  @@index([tableId, reservationDate])
  @@index([status])
  @@index([bookingKind])
  @@index([guestId])
}

model Guest {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  phone        String?
  name         String?
  shellBalance Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  reservations       Reservation[]
  favorites          GuestFavoriteUnit[]
  favoriteOrders     GuestFavoriteOrder[]
  magicLinks         GuestMagicLink[]
  shellTransactions  ShellTransaction[]
  payments           Payment[]

  @@index([phone])
}

model GuestMagicLink {
  id        Int      @id @default(autoincrement())
  guestId   Int
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([guestId])
}

model GuestFavoriteUnit {
  id         Int        @id @default(autoincrement())
  guestId    Int
  guest      Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  kind       String     @default("table")
  tableId    Int?
  table      VenueTable? @relation(fields: [tableId], references: [id], onDelete: Cascade)
  menuItemId Int?
  menuItem   MenuItem?   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())

  @@unique([guestId, kind, tableId])
  @@unique([guestId, kind, menuItemId])
  @@index([guestId])
}

model GuestFavoriteOrder {
  id        Int      @id @default(autoincrement())
  guestId   Int
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  name      String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestId])
}

model ShellTransaction {
  id          Int               @id @default(autoincrement())
  guestId     Int
  guest       Guest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  type        ShellTxType
  amount      Decimal           @db.Decimal(10, 2)
  balanceAfter Decimal          @db.Decimal(10, 2)
  source      ShellSource
  description String?
  referenceId Int?
  createdAt   DateTime          @default(now())

  @@index([guestId])
  @@index([createdAt])
}

enum ShellTxType {
  TOPUP
  EARN
  SPEND
  ADJUST
}

enum ShellSource {
  REGISTRATION
  TICKET_PURCHASE
  MENU_ORDER
  TOPUP
  ADMIN_ADJUSTMENT
}

model TableHold {
  id              Int             @id @default(autoincrement())
  tableId         Int
  reservationId   Int?
  eventId         Int?
  holdToken       String          @unique
  reservationDate DateTime
  timeFrom        DateTime
  timeTo          DateTime
  expiresAt       DateTime
  status          TableHoldStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  event           Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reservation     Reservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  table           VenueTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([reservationId])
  @@index([eventId])
  @@index([reservationDate])
  @@index([expiresAt])
  @@index([status])
}

model Payment {
  id                Int           @id @default(autoincrement())
  reservationId     Int?          @unique
  ticketOrderId     Int?          @unique
  guestId           Int?
  provider          String
  providerPaymentId String?
  providerOrderId   String?
  paymentUrl        String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("UAH")
  status            PaymentStatus @default(PENDING)
  rawPayload        Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  reservation       Reservation?  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  ticketOrder       TicketOrder?  @relation(fields: [ticketOrderId], references: [id], onDelete: Cascade)
  guest             Guest?        @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([ticketOrderId])
  @@index([providerPaymentId])
  @@index([providerOrderId])
  @@index([status])
  @@index([guestId])
}

model Event {
  id               Int           @id @default(autoincrement())
  title            Json
  slug             String        @unique
  shortDescription Json?
  fullDescription  Json?
  posterImage      String?
  startAt          DateTime
  endAt            DateTime?
  status           EventStatus   @default(DRAFT)
  isFeatured       Boolean       @default(false)
  ctaType          EventCtaType  @default(BOOKING)
  preferredMapUsageMode MapUsageMode?
  ticketUrl        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservations     Reservation[]
  tableHolds       TableHold[]
  tableOverrides   VenueTableOverride[]
  sessions         EventSession[]
  ticketTypes      TicketType[]
  ticketOrders     TicketOrder[]
  tickets          Ticket[]

  @@index([slug])
  @@index([status])
  @@index([startAt])
  @@index([isFeatured])
  @@index([preferredMapUsageMode])
}

model EventSession {
  id        Int       @id @default(autoincrement())
  eventId    Int
  name       Json?
  startsAt   DateTime
  endsAt     DateTime
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  admissionMode EventAdmissionMode @default(TICKETED)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes TicketType[]
  ticketOrders TicketOrder[]
  tickets    Ticket[]

  @@index([eventId])
  @@index([startsAt])
  @@index([sortOrder])
}

model TicketType {
  id          Int      @id @default(autoincrement())
  eventId     Int
  eventSessionId Int?
  name        Json
  description Json?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("UAH")
  capacity    Int
  soldCount   Int      @default(0)
  salesStart  DateTime?
  salesEnd    DateTime?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventSession EventSession? @relation(fields: [eventSessionId], references: [id], onDelete: SetNull)
  tickets     Ticket[]

  @@index([eventId])
  @@index([eventSessionId])
  @@index([isActive])
  @@index([sortOrder])
}

model TicketOrder {
  id            Int               @id @default(autoincrement())
  eventId       Int
  eventSessionId Int?
  orderNumber   String            @unique
  downloadToken String            @unique
  customerName  String
  customerEmail String
  customerPhone String?
  amount        Decimal           @db.Decimal(10, 2)
  currency      String            @default("UAH")
  status        TicketOrderStatus @default(PENDING)
  expiresAt     DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  event         Event             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventSession  EventSession?     @relation(fields: [eventSessionId], references: [id], onDelete: SetNull)
  payment       Payment?
  tickets       Ticket[]

  @@index([eventId])
  @@index([eventSessionId])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model Ticket {
  id           Int          @id @default(autoincrement())
  orderId      Int
  eventId      Int
  eventSessionId Int?
  ticketTypeId Int
  code         String       @unique
  status       TicketStatus @default(RESERVED)
  holderName   String?
  holderEmail  String?
  issuedAt     DateTime?
  usedAt       DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  order        TicketOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventSession EventSession? @relation(fields: [eventSessionId], references: [id], onDelete: SetNull)
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  scans        TicketScan[]

  @@index([orderId])
  @@index([eventId])
  @@index([eventSessionId])
  @@index([ticketTypeId])
  @@index([status])
}

model TicketScan {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  adminUserId Int?
  result      String
  note        String?
  scannedAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([scannedAt])
}

model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      Json
  slug      String     @unique
  section   MenuSection @default(KITCHEN)
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  noPhoto   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]

  @@index([sortOrder])
  @@index([isActive])
  @@index([section])
}

model MenuItem {
  id          Int          @id @default(autoincrement())
  categoryId  Int
  name        Json
  description Json?
  price       Decimal      @db.Decimal(10, 2)
  imageUrl    String?
  likesCount  Int          @default(0)
  isActive    Boolean      @default(true)
  isAvailable Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  TableOrderItem[]
  favoriteUnits GuestFavoriteUnit[]

  @@index([categoryId])
  @@index([sortOrder])
  @@index([likesCount])
  @@index([isActive])
  @@index([isAvailable])
}

model News {
  id        Int      @id @default(autoincrement())
  title     Json
  body      Json
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FrontendSettings {
  id           Int      @id @default(autoincrement())
  title        Json?
  description  Json?
  keywords     Json?
  logoUrl      String?
  faviconUrl   String?
  phone        String?
  email        String?
  address      Json?
  mapEmbedUrl  String?
  workingHours Json?
  socialMedia  Json?
  heroTitle    Json?
  heroSubtitle Json?
  aboutTitle   Json?
  aboutText    Json?
  aboutImageUrl String?
  galleryImages Json?
  footerText    Json?
  reportRecipients Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReservationLog {
  id            Int                @id @default(autoincrement())
  reservationId Int
  action        String
  oldStatus     ReservationStatus?
  newStatus     ReservationStatus?
  comment       String?
  createdAt     DateTime           @default(now())
  reservation   Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

enum MapStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MapUsageMode {
  DAY
  EVENING
  EVENT
}

enum BookingKind {
  TABLE
  BEACH
}

enum ReservationStatus {
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  SEATED
  CANCELLED
  COMPLETED
  NO_SHOW
  EXPIRED
}

enum MapObjectType {
  TABLE
  LABEL
  BAR
  STAGE
  POOL
  WALL
  ENTRANCE
  WC
  DECOR
  STAIRS
  PATH
  CUSTOM
  TEXT
}

enum VenuePositionSide {
  LEFT
  RIGHT
  CENTER
}

enum ReservationSource {
  WEB
  ADMIN
  PHONE
  WALK_IN
  EVENT
  INSTAGRAM
  FACEBOOK
}

enum TableHoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  RELEASED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventCtaType {
  BOOKING
  TICKETS
  BOTH
}

enum EventAdmissionMode {
  FREE
  TICKETED
}

enum TicketOrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
}

enum TicketStatus {
  RESERVED
  VALID
  USED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum MenuSection {
  KITCHEN
  BAR
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  COMPLETED
  CANCELLED
}

enum CallStatus {
  PENDING
  ACCEPTED
}

model Waiter {
  id             Int            @id @default(autoincrement())
  name           String
  pinCode        String         @unique
  telegramChatId String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  shifts         WaiterShift[]
  orders         TableOrder[]
  calls          WaiterCall[]
}

model WaiterShift {
  id        Int                 @id @default(autoincrement())
  waiterId  Int
  startedAt DateTime            @default(now())
  endedAt   DateTime?
  isActive  Boolean             @default(true)
  waiter    Waiter              @relation(fields: [waiterId], references: [id])
  tables    WaiterShiftTable[]
  orders    TableOrder[]

  @@index([waiterId])
}

model WaiterShiftTable {
  id         Int         @id @default(autoincrement())
  shiftId    Int
  tableId    Int
  assignedAt DateTime    @default(now())
  shift      WaiterShift @relation(fields: [shiftId], references: [id])

  @@unique([shiftId, tableId])
  @@index([shiftId])
}

model TableOrder {
  id             Int              @id @default(autoincrement())
  tableId        Int
  shiftId        Int?
  waiterId       Int?
  status         OrderStatus      @default(PENDING)
  customerName   String?
  customerPhone  String?
  notes          String?
  createdAt      DateTime         @default(now())
  acceptedAt     DateTime?
  completedAt    DateTime?
  shift          WaiterShift?     @relation(fields: [shiftId], references: [id])
  waiter         Waiter?          @relation(fields: [waiterId], references: [id])
  table          VenueTable?      @relation(fields: [tableId], references: [id])
  items          TableOrderItem[]

  @@index([tableId])
  @@index([waiterId])
  @@index([status])
}

model TableOrderItem {
  id         Int       @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  quantity   Int       @default(1)
  price      Decimal   @db.Decimal(10, 2)
  notes      String?
  order      TableOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
}

model WaiterCall {
  id          Int        @id @default(autoincrement())
  tableId     Int
  waiterId    Int?
  status      CallStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  respondedAt DateTime?
  waiter      Waiter?    @relation(fields: [waiterId], references: [id])
  table       VenueTable? @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@index([waiterId])
  @@index([status])
}

model ReportSchedule {
  id             Int               @id @default(autoincrement())
  name           String
  reportType     ReportType
  frequency      ReportFrequency   @default(WEEKLY)
  recipientEmail String
  recipientName  String?
  isActive       Boolean           @default(true)
  dayOfWeek      Int?
  hour           Int               @default(9)
  lastSentAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([reportType])
  @@index([frequency])
  @@index([isActive])
}

enum ReportType {
  FINANCIAL
  RESERVATIONS
  TICKETS
  MENU
  EVENTS
  STAFF
  SUMMARY
  OCCUPANCY
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model OccupancySnapshot {
  id               Int      @id @default(autoincrement())
  date             DateTime @unique
  beachOccupied    Int      @default(0)
  beachCapacity    Int      @default(0)
  beachPct         Float    @default(0)
  beachGuests      Int      @default(0)
  tableOccupied    Int      @default(0)
  tableCapacity    Int      @default(0)
  tablePct         Float    @default(0)
  tableGuests      Int      @default(0)
  eveningEvents    Int      @default(0)
  totalGuests      Int      @default(0)
  onPremises       Int      @default(0)
  arrived          Int      @default(0)
  totalReservations Int    @default(0)
  createdAt        DateTime @default(now())

  @@index([date])
}
