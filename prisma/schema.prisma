generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Map {
  id              Int           @id @default(autoincrement())
  name            Json
  slug            String        @unique
  description     Json?
  status          MapStatus     @default(DRAFT)
  isDefault       Boolean       @default(false)
  width           Int
  height          Int
  backgroundImage String?
  backgroundColor String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
  tables          VenueTable[]
  zones           Zone[]
  mapObjects      MapObject[]

  @@index([status])
  @@index([isDefault])
}

model Zone {
  id           Int           @id @default(autoincrement())
  mapId        Int
  name         Json
  color        String
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  map          Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  tables       VenueTable[]

  @@index([mapId])
}

model VenueTable {
  id           Int           @id @default(autoincrement())
  mapId        Int
  zoneId       Int
  name         Json
  code         String?
  photoUrl     String?
  seatsMin     Int
  seatsMax     Int
  deposit      Decimal       @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  isBookable   Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  map          Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  zone         Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  mapObjects   MapObject[]
  reservations Reservation[]
  tableHolds   TableHold[]

  @@index([mapId])
  @@index([zoneId])
}

model MapObject {
  id        Int           @id @default(autoincrement())
  mapId     Int
  tableId   Int?
  type      MapObjectType
  label     Json?
  x         Float
  y         Float
  width     Float
  height    Float
  rotation  Float         @default(0)
  zIndex    Int           @default(0)
  styleJson Json?
  metaJson  Json?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  map       Map           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  table     VenueTable?   @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([mapId])
  @@index([tableId])
  @@index([isActive])
}

model Reservation {
  id              Int               @id @default(autoincrement())
  tableId         Int
  mapId           Int
  zoneId          Int
  eventId         Int?
  customerName    String
  customerPhone   String
  customerEmail   String?
  guests          Int
  reservationDate DateTime
  timeFrom        DateTime
  timeTo          DateTime
  status          ReservationStatus @default(PENDING)
  source          ReservationSource @default(WEB)
  ticketCode      String?
  arrivedAt       DateTime?
  arrivedGuests   Int?
  commentCustomer String?
  commentAdmin    String?
  depositRequired Boolean           @default(false)
  depositAmount   Decimal?          @db.Decimal(10, 2)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  event           Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  map             Map               @relation(fields: [mapId], references: [id], onDelete: Restrict)
  zone            Zone              @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  table           VenueTable        @relation(fields: [tableId], references: [id], onDelete: Restrict)
  payment         Payment?
  logs            ReservationLog[]
  tableHolds      TableHold[]

  @@index([tableId])
  @@index([mapId])
  @@index([zoneId])
  @@index([eventId])
  @@index([reservationDate])
  @@index([tableId, reservationDate])
  @@index([status])
}

model TableHold {
  id              Int             @id @default(autoincrement())
  tableId         Int
  reservationId   Int?
  eventId         Int?
  holdToken       String          @unique
  reservationDate DateTime
  timeFrom        DateTime
  timeTo          DateTime
  expiresAt       DateTime
  status          TableHoldStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  event           Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reservation     Reservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  table           VenueTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([reservationId])
  @@index([eventId])
  @@index([reservationDate])
  @@index([expiresAt])
  @@index([status])
}

model Payment {
  id                Int           @id @default(autoincrement())
  reservationId     Int           @unique
  provider          String
  providerPaymentId String?
  providerOrderId   String?
  paymentUrl        String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("UAH")
  status            PaymentStatus @default(PENDING)
  rawPayload        Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  reservation       Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([providerPaymentId])
  @@index([providerOrderId])
  @@index([status])
}

model Event {
  id               Int           @id @default(autoincrement())
  title            Json
  slug             String        @unique
  shortDescription Json?
  fullDescription  Json?
  posterImage      String?
  startAt          DateTime
  endAt            DateTime?
  status           EventStatus   @default(DRAFT)
  isFeatured       Boolean       @default(false)
  ctaType          EventCtaType  @default(BOOKING)
  ticketUrl        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservations     Reservation[]
  tableHolds       TableHold[]

  @@index([slug])
  @@index([status])
  @@index([startAt])
  @@index([isFeatured])
}

model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      Json
  slug      String     @unique
  section   MenuSection @default(KITCHEN)
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]

  @@index([sortOrder])
  @@index([isActive])
  @@index([section])
}

model MenuItem {
  id          Int          @id @default(autoincrement())
  categoryId  Int
  name        Json
  description Json?
  price       Decimal      @db.Decimal(10, 2)
  imageUrl    String?
  likesCount  Int          @default(0)
  isActive    Boolean      @default(true)
  isAvailable Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([sortOrder])
  @@index([likesCount])
  @@index([isActive])
  @@index([isAvailable])
}

model News {
  id        Int      @id @default(autoincrement())
  title     Json
  body      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FrontendSettings {
  id           Int      @id @default(autoincrement())
  title        Json?
  description  Json?
  keywords     Json?
  logoUrl      String?
  faviconUrl   String?
  phone        String?
  email        String?
  address      Json?
  mapEmbedUrl  String?
  workingHours Json?
  socialMedia  Json?
  heroTitle    Json?
  heroSubtitle Json?
  footerText   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReservationLog {
  id            Int                @id @default(autoincrement())
  reservationId Int
  action        String
  oldStatus     ReservationStatus?
  newStatus     ReservationStatus?
  comment       String?
  createdAt     DateTime           @default(now())
  reservation   Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

enum MapStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ReservationStatus {
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  EXPIRED
}

enum MapObjectType {
  TABLE
  LABEL
  BAR
  STAGE
  POOL
  WALL
  ENTRANCE
  WC
  DECOR
  STAIRS
  PATH
  CUSTOM
}

enum ReservationSource {
  WEB
  ADMIN
  PHONE
  WALK_IN
  EVENT
  INSTAGRAM
  FACEBOOK
}

enum TableHoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  RELEASED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventCtaType {
  BOOKING
  TICKETS
  BOTH
}

enum MenuSection {
  KITCHEN
  BAR
}
